# Copy to .env and adjust values. Never commit the real .env file.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/erp
SECRET_KEY=generate-a-long-random-secret-here
DEBUG=true
# Dev only. In production set to false and manage the schema with:
#   alembic upgrade head
AUTO_CREATE_TABLES=true
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin@1234
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
