# Copy to .env and adjust values. Never commit the real .env file.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/erp
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# In production (DEBUG=false) the app refuses to start unless this is changed
# from its insecure default.
SECRET_KEY=generate-a-long-random-secret-here
# Dev only: enables interactive API docs (/docs, /redoc) and allows the
# insecure default SECRET_KEY. Set to false in production.
DEBUG=true
# Dev only. In production, leave this false (the default) and manage the
# schema with:
#   alembic upgrade head
AUTO_CREATE_TABLES=true
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin@1234
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
